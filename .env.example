APP_ENV=development

POSTGRES_USER=retrosnap
POSTGRES_PASSWORD=retrosnap
POSTGRES_DB=retrosnap
DATABASE_URL=postgres://retrosnap:retrosnap@postgres:5432/retrosnap?sslmode=disable

ADMIN_TOKEN=change-me
GUEST_TOKEN_SECRET=change-me

PUBLIC_GUEST_APP_URL=http://localhost:5173
PUBLIC_DASHBOARD_URL=http://localhost:5175
PUBLIC_API_URL=http://localhost:8080

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=retrosnap-photos
S3_ACCESS_KEY_ID=retrosnap
S3_SECRET_ACCESS_KEY=retrosnap-local-secret
S3_FORCE_PATH_STYLE=true

R2_ENDPOINT=http://minio:9000
R2_REGION=auto
R2_BUCKET=retrosnap-photos
R2_ACCESS_KEY_ID=retrosnap
R2_SECRET_ACCESS_KEY=retrosnap-local-secret
R2_FORCE_PATH_STYLE=true

WORKER_CONCURRENCY=1
WORKER_BATCH_SIZE=5
WORKER_POLL_INTERVAL_MS=5000
WORKER_STALE_PROCESSING_MINUTES=15
MAX_PROCESSING_ATTEMPTS=8

ENABLE_TIMESTAMP_OVERLAY=true
TIMEZONE=Asia/Kuala_Lumpur
